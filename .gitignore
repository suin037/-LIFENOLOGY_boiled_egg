# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env

# ── 원본은 디렉토리 통째로 제외 (.gitkeep만 유지) ──
# 확장자를 나열하면 새 포맷이 들어올 때마다 구멍이 생긴다.
# (실제로 *.sav 만 막던 시절 CHS 의 .sas7bdat 368MB 가 그대로 통과했음)
data/raw/*
!data/raw/.gitkeep

# 개인 단위 정제본도 제외 — 원자료로 재생성 가능
data/processed/*
!data/processed/.gitkeep
data/goms_clean.csv

# 데모용 합성 데이터 (가짜) — training/make_synthetic.py 로 재생성
data/klips_clean.csv
data/klips_survival.csv

# Model artifacts
backend/models/artifacts/*.pkl

# Node / frontend
node_modules/
frontend/dist/

# OS / editor
.DS_Store
.vscode/
.idea/

# ── 전역 안전망 (README 6절) ──
# 위 디렉토리 규칙을 벗어난 위치에 원자료가 놓여도 잡히도록 확장자로 한 번 더 막는다.
# 사회통합실태조사 원자료 (개인 단위 데이터 — 재배포 금지)
*사회통합실태조사_데이터*.xlsx
*사회통합실태조사*.SAV
*.sav

# KNHANES / CHS / KWCS 원자료 (개인 단위 — 재배포 금지)
*.sas7bdat
*_person_level.csv

# 보고서 PDF 원문 (재배포 이슈)
*.pdf

# 설문지·개요서 원본
*.hwp
*.hwpx

# KOSIS/KEDI 원본 다운로드 파일 (팀 판단으로 포함 시 이 두 줄 삭제)
*_2026*.csv
*_2025*.csv

# ── 일반 ──
.DS_Store
Thumbs.db
~$*.xlsx

# 심리카드 벡터DB(재생성 가능, 커밋 안 함)
data/vectordb/
