# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env

# Data 원본은 전부 제외 (.gitkeep만 유지) — GOMS .SAV, YP .xlsx, 논문 PDF 등
data/raw/*
!data/raw/.gitkeep

# 아래는 의도적으로 공유함(팀원이 원본 없이 바로 작업하도록):
#   data/clean/*.csv      — 전처리 산출물 (표준변수명 인터페이스)
#   data/knowledge/*.json — 직접 작성한 지식 카드 (재생성 불가)
#   data/vectordb/**/*.pkl— RAG 벡터DB

# 사람이 보는 preview 파일만 제외 (pkl에서 재생성 가능)
data/vectordb/**/psychology_db_preview.*

# Model artifacts
backend/models/artifacts/*.pkl

# Node / frontend
node_modules/
frontend/dist/

# OS / editor
.DS_Store
.vscode/
.idea/
